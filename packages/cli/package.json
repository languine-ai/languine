{
  "name": "languine",
  "version": "4.0.1",
  "description": "Self-hosted CLI for Languine — AI-powered localization for your codebase. Talks to a Languine deployment you run on your own Vercel account.",
  "type": "module",
  "bin": "dist/index.js",
  "license": "MIT",
  "homepage": "https://github.com/languine-ai/languine#readme",
  "bugs": {
    "url": "https://github.com/languine-ai/languine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/languine-ai/languine.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "languine",
    "i18n",
    "l10n",
    "localization",
    "translation",
    "ai",
    "cli",
    "self-hosted"
  ],
  "scripts": {
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsup --clean",
    "dev": "tsup --watch --clean",
    "start": "node dist/index.js",
    "test": "bun test",
    "prepublishOnly": "bun run build",
    "publish:selfhosted": "npm publish --tag=selfhosted"
  },
  "files": ["dist", "README.md"],
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "chalk": "^5.6.2",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "dedent": "^1.5.3",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^4.5.1",
    "gettext-parser": "^8.0.0",
    "jscodeshift": "^17.1.2",
    "jsdom": "^29.1.1",
    "json2php": "^0.0.12",
    "json5": "^2.2.3",
    "jsonrepair": "^3.11.2",
    "open": "^11.0.0",
    "php-parser": "^3.1.5",
    "plist": "^3.1.0",
    "preferred-pm": "^4.1.1",
    "properties": "^1.2.1",
    "rambda": "^9.4.2",
    "simple-git": "^3.36.0",
    "superjson": "^2.2.6",
    "table-layout": "^4.1.1",
    "xliff": "^6.2.1",
    "xml2js": "^0.6.2",
    "yaml": "^2.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@languine/web": "workspace:*",
    "@types/gettext-parser": "^4.0.4",
    "@types/jscodeshift": "^0.12.0",
    "@types/mdast": "^4.0.4",
    "@types/plist": "^3.0.5",
    "@types/xml2js": "^0.4.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
