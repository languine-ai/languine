# Neon Postgres - auto-injected by the Vercel Marketplace integration
DATABASE_URL=

# Random API key the CLI / GitHub Action will use. Generate with `openssl rand -hex 32`.
LANGUINE_API_KEY=

# Optional: Vercel AI Gateway model slug. Default: openai/gpt-4.1
# Examples: anthropic/claude-sonnet-4, openai/gpt-4.1-mini
AI_MODEL=openai/gpt-4.1

# Optional: only required for local development outside Vercel.
# In production on Vercel, the Gateway authenticates via OIDC automatically.
AI_GATEWAY_API_KEY=
